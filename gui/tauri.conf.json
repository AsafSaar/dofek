{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "dofek",
  "version": "1.0.0",
  "identifier": "com.dofek.app",
  "build": {
    "frontendDist": "frontend"
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../target/release/dofek-tui"
    ],
    "resources": {
      "../docs/manual.html": "manual.html",
      "../docs/assets/tui-screenshot.png": "assets/tui-screenshot.png",
      "../docs/assets/gui-screenshot.png": "assets/gui-screenshot.png",
      "../README-install.txt": "README.txt"
    },
    "windows": {
      "wix": {
        "fragmentPaths": ["wix/manual-shortcut.wxs"],
        "componentRefs": ["ManualShortcutComponent"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "dofek — system monitor",
        "width": 1400,
        "height": 850,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com"
    }
  }
}
