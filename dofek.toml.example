# dofek.toml — copy this file to one of:
#   Windows: %APPDATA%\dofek\dofek.toml
#   Linux:   ~/.config/dofek/dofek.toml
#   macOS:   ~/Library/Application Support/dofek/dofek.toml
# or pass --config <path> on the dofek-tui command line.

[general]
refresh_ms = 500
history_len = 60

[display]
show_temps = true
show_power = true
process_count = 10

[ai]
vram_threshold_gb = 1.0
known_ai_processes = ["ollama", "ollama_llama_server", "python", "lm_studio", "claude"]

[categories]
dev_processes = ["code", "cargo", "rustc", "node", "npm", "git", "docker", "go"]
watch_processes = ["ffmpeg", "obs"]
# watch_pids = [1234]

# LHM is a Windows-only sensor source (CPU temp/power, AMD GPU fallback).
# On Linux this section is harmless — Dofek reads CPU temperature directly from
# /sys/class/hwmon via sysinfo and ignores LHM connection failures.
# On macOS this section is also harmless — CPU temperature/power and GPU/VRAM
# panels show N/A in v1.2 (Apple Silicon SMC integration is on the roadmap).
[lhm]
url = "http://localhost:8085"

# Telemetry: opt-in anonymous usage data for beta feedback.
# Disabled by default. Enable to help improve Dofek.
# [telemetry]
# enabled = true
# endpoint = "https://dofek.dev/api/v1/events"
# flush_interval_secs = 60

# Plugins: external processes that inject data into the dashboard.
# Each [[plugins]] entry spawns a child process communicating via JSON-over-stdio.
# See plugins/README.md for the protocol, or https://dofek.dev/plugins/ for live docs.
#
# First-party plugins (build from this repo or grab the binaries from a release):
#   cargo build --release -p dofek-ollama -p dofek-docker
# then put the binaries on PATH and uncomment the block(s) below.

# [[plugins]]
# name = "ollama"
# command = "dofek-ollama"
# args = ["--host", "http://localhost:11434"]
# enabled = true
# timeout_ms = 2000

# [[plugins]]
# name = "docker"
# command = "dofek-docker"
# args = ["--host", "http://localhost:2375"]
# enabled = true
# timeout_ms = 2000
